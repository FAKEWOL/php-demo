<?php
    $numbers = [];
    for ($i = 0; $i < 5; $i++) {
        array_unshift($numbers, rand(1, 10));
    }

    echo '<pre>';
    print_r($numbers);
    echo 'Dizideki Eleman Sayısı: ' . count($numbers) . '<br>';
    echo 'Dizideki Sayısal Değerlerin Toplamı: ' . array_sum($numbers) . '<br>';
    echo 'Dizideki Sayısal Değerlerin Çarpımı: ' . array_product($numbers) . '<br>';
    echo '</pre>';
    print_r(array_count_values($numbers));
?>